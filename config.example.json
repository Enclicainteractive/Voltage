{
  "server": {
    "name": "Volt",
    "version": "1.0.0",
    "mode": "mainline",
    "url": "https://volt.voltagechat.app",
    "imageServerUrl": "https://volt.voltagechat.app"
  },
  "branding": {
    "logo": null,
    "primaryColor": "#5865f2",
    "accentColor": "#7289da"
  },
  "storage": {
    "type": "sqlite",
    "sqlite": {
      "dbPath": "./data/voltage.db"
    },
    "mysql": {
      "host": "localhost",
      "port": 3306,
      "database": "voltchat",
      "user": "root",
      "password": "",
      "connectionLimit": 10
    },
    "mariadb": {
      "host": "localhost",
      "port": 3306,
      "database": "voltchat",
      "user": "root",
      "password": ""
    },
    "postgres": {
      "host": "localhost",
      "port": 5432,
      "database": "voltchat",
      "user": "postgres",
      "password": ""
    },
    "cockroachdb": {
      "host": "localhost",
      "port": 26257,
      "database": "voltchat",
      "user": "root",
      "password": "",
      "ssl": true
    },
    "mssql": {
      "host": "localhost",
      "port": 1433,
      "database": "voltchat",
      "user": "sa",
      "password": ""
    },
    "mongodb": {
      "host": "localhost",
      "port": 27017,
      "database": "voltchat",
      "user": "",
      "password": ""
    },
    "redis": {
      "host": "localhost",
      "port": 6379,
      "password": "",
      "db": 0
    }
  },
  "cdn": {
    "enabled": false,

    "_comment_provider": "Options: 'local' (default), 'nfs' (shared folder across VPS nodes), 's3' (AWS S3 or compatible), 'cloudflare' (Cloudflare R2)",
    "provider": "local",

    "local": {
      "uploadDir": "./uploads",
      "baseUrl": null
    },

    "_comment_nfs": "NFS: mount a shared folder from your Storage Master so all nodes see the same files. Set provider to 'nfs' and point uploadDir at the mount path. See docs/SCALING.md for the full setup guide.",
    "nfs": {
      "_comment_uploadDir": "The local path where the NFS share is mounted. Must be mounted BEFORE starting Voltage.",
      "uploadDir": "/www/shared_uploads",
      "baseUrl": null
    },

    "s3": {
      "bucket": "my-volt-media",
      "region": "us-east-1",
      "accessKeyId": "",
      "secretAccessKey": "",
      "endpoint": null,
      "publicUrl": "https://cdn.mydomain.com"
    }
  },
  "cache": {
    "enabled": true,
    "provider": "redis",
    "redis": {
      "host": "localhost",
      "port": 6379,
      "password": "",
      "db": 0
    }
  },
  "queue": {
    "enabled": false,
    "provider": "memory"
  },
  "auth": {
    "type": "all",
    "local": {
      "enabled": true,
      "allowRegistration": true,
      "minPasswordLength": 8
    },
    "oauth": {
      "enabled": true,
      "provider": "enclica",
      "enclica": {
        "clientId": "app_54f92e4d526840789998b4cca492aea1",
        "authUrl": "https://api.enclicainteractive.com/oauth/authorize",
        "tokenUrl": "https://api.enclicainteractive.com/api/oauth/token",
        "userInfoUrl": "https://api.enclicainteractive.com/api/user/me"
      }
    }
  },
  "security": {
    "jwtSecret": "CHANGE_ME_IN_PRODUCTION",
    "jwtExpiry": "7d",
    "bcryptRounds": 12,
    "rateLimit": {
      "windowMs": 60000,
      "maxRequests": 100
    }
  },
  "federation": {
    "enabled": false,
    "serverName": null,
    "maxHops": 3
  },
  "features": {
    "discovery": true,
    "selfVolt": true,
    "voiceChannels": true,
    "videoChannels": true,
    "e2eEncryption": true,
    "e2eTrueEncryption": true,
    "communities": true,
    "bots": true,
    "federation": true
  },
  "limits": {
    "maxUploadSize": 10485760,
    "maxServersPerUser": 100,
    "maxMessageLength": 4000
  },
  "monitoring": {
    "enabled": false,
    "prometheus": false
  },

  "_comment_scaling": "SCALING — NOT FEDERATION. Same Voltage instance across multiple VPS. All nodes share the same database. HAProxy/nginx sits in front.",
  "scaling": {
    "enabled": false,

    "_comment_nodeSecret": "Shared secret — ALL nodes must have the SAME value. Change this.",
    "nodeSecret": "CHANGE_ME_SAME_ON_ALL_NODES",

    "_comment_nodeId": "Unique ID for THIS node. Short slug. e.g. node-1, vps-nyc, eu-west",
    "nodeId": "node-1",

    "_comment_nodeUrl": "Public (or internal) URL that OTHER nodes use to reach THIS node.",
    "nodeUrl": "https://node1.myvolt.example.com",

    "_comment_nodes": "Full list of ALL nodes (including self). Copy this identical block to every node's config.",
    "nodes": [
      {
        "id": "node-1",
        "url": "https://node1.myvolt.example.com"
      },
      {
        "id": "node-2",
        "url": "https://node2.myvolt.example.com"
      }
    ],

    "_comment_heartbeatInterval": "How often (ms) to ping peer nodes. Default 30s.",
    "heartbeatInterval": 30000,

    "_comment_heartbeatTimeout": "How long (ms) of silence before a node is marked offline. Default 90s.",
    "heartbeatTimeout": 90000,

    "_comment_fileResolutionMode": "'proxy' = stream file through this node (hides peers). 'redirect' = 302 to peer (faster, exposes peer URL).",
    "fileResolutionMode": "proxy"
  }
}
